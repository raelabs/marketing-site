---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Splash from '../components/Splash.astro';
import HeroRotating from '../components/HeroRotating.astro';
import LogoMarquee from '../components/LogoMarquee.astro';
import ProductSection from '../components/ProductSection.astro';
import AgentHarnessBar from '../components/AgentHarnessBar.astro';
import TraceBar from '../components/TraceBar.astro';
import { ContactButton } from '../components/ContactButton';
---

<BaseLayout
  title="rae labs - the trust harness for autonomous engineering"
  description="Architected for ultra-productive (agent) dev teams."
>
  <Splash />
  <Nav />

  <main>
    <HeroRotating />
    <LogoMarquee />
    <ProductSection
      id="products"
      headline="Manage massive agent teams with confidence"
      body="Real-time work tracking, decision tracing, and code reviews. 2-10x your team without losing any context (or sanity)."
      screenshotName="Lightfield"
      screenshotAccent="var(--primary)"
      screenshotDark="/images/screenshots/session-traces-focused-dark.png"
      screenshotLight="/images/screenshots/session-traces-focused-light.png"
      layout="left"
      reveal
      revealDelay="1.4s"
      ctaText="Learn more about the context control plane"
      ctaHref="/products/lightfield"
    />
    <AgentHarnessBar />
    <ProductSection
      headline="Full autonomy with full control"
      body="Deterministic, granular, context-anchored permissions for coding agents. The blast radius of AI errors demands more than a container and a pre-commit hook."
      screenshotName="Prism"
      screenshotAccent="var(--secondary)"
      screenshotDark="/images/prism-hero.jpg"
      screenshotLight="/images/prism-hero.jpg"
      screenshotPosition="center"
      layout="right"
      badge="Coming in Q2"
      badgePrefix="Prism"
    />
    <TraceBar />

    <section class="py-24 px-6 bg-muted/20">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-title mb-4">Ready to trust your (agent) dev team?</h2>
        <p class="text-lg text-muted-foreground mb-8">Join the research preview and start autonomously engineering, responsibly.</p>
        <ContactButton
          client:load
          source="homepage_cta"
          className="inline-block text-base font-medium px-8 py-3 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Join Research Preview
        </ContactButton>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
