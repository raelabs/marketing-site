---
import ScreenshotPlaceholder from './ScreenshotPlaceholder.astro';

interface Props {
  headline: string;
  body: string;
  screenshotName: string;
  screenshotAccent?: string;
  layout?: 'left' | 'right';
  id?: string;
  reveal?: boolean;
  revealDelay?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  headline,
  body,
  screenshotName,
  screenshotAccent = 'var(--primary)',
  layout = 'left',
  id,
  reveal = false,
  revealDelay = '0s',
  ctaText,
  ctaHref = '#',
} = Astro.props;
---

<section id={id} class:list={['py-24 px-6', reveal && 'hero-reveal']} style={reveal ? `animation-delay: ${revealDelay};` : undefined}>
  <div class:list={[
    'max-w-6xl mx-auto flex flex-col gap-12',
    layout === 'left' ? 'md:flex-row' : 'md:flex-row-reverse',
    'items-center'
  ]}>
    <div class="flex-1 md:max-w-md">
      <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">{headline}</h2>
      <p class="text-lg text-muted-foreground leading-relaxed">{body}</p>
      {ctaText && (
        <a href={ctaHref} class="inline-block mt-8 text-lg text-muted-foreground underline underline-offset-4 hover:text-foreground transition-colors">
          {ctaText} →
        </a>
      )}
    </div>
    <div class="flex-1 w-full">
      <ScreenshotPlaceholder name={screenshotName} accentColor={screenshotAccent} />
    </div>
  </div>
</section>
