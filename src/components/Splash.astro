---
/**
 * Landing splash overlay — plays once per visitor.
 * Pure CSS keyframe animations, localStorage to prevent repeat.
 */
---

<div id="splash-overlay" class="splash-overlay">
  <div class="splash-content">
    <p class="splash-large splash-phase-1">hey engineers and execs</p>
    <p class="splash-small splash-phase-2">the age of</p>
    <p class="splash-large splash-phase-2">autonomous engineering</p>
    <p class="splash-small splash-phase-2">has arrived</p>
    <p class="splash-small splash-phase-3">it&apos;s time to</p>
    <p class="splash-large splash-phase-3">trust your (agent) dev team</p>
  </div>
</div>

<script is:inline>
  (function() {
    var overlay = document.getElementById('splash-overlay');
    if (!overlay) return;

    if (localStorage.getItem('rae-splash-seen')) {
      overlay.remove();
      return;
    }

    overlay.classList.add('splash-active');

    setTimeout(function() {
      overlay.classList.add('splash-fade-out');
      localStorage.setItem('rae-splash-seen', '1');
    }, 4000);

    setTimeout(function() {
      overlay.remove();
    }, 5000);
  })();
</script>

<style>
  .splash-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    background: oklch(0.15 0.04 285);
  }

  .splash-overlay.splash-active {
    display: flex;
  }

  .splash-overlay.splash-fade-out {
    animation: splashFadeOut 1s ease-in-out forwards;
  }

  .splash-content {
    text-align: center;
    padding: 1.5rem;
    max-width: 100vw;
  }

  .splash-large {
    font-size: clamp(1.5rem, 5vw, 3.5rem);
    font-weight: 700;
    color: oklch(0.99 0.005 85);
    line-height: 1.2;
    opacity: 0;
  }

  .splash-small {
    font-size: clamp(0.875rem, 2.5vw, 1.5rem);
    font-weight: 400;
    color: oklch(0.77 0.00 0);
    line-height: 1.4;
    opacity: 0;
  }

  .splash-active .splash-phase-1 {
    animation: splashFadeIn 0.6s ease-out 0.2s forwards;
  }

  .splash-active .splash-phase-2 {
    animation: splashFadeIn 0.6s ease-out 1.0s forwards;
  }

  .splash-active .splash-phase-3 {
    animation: splashFadeIn 0.6s ease-out 2.0s forwards;
  }

  @keyframes splashFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes splashFadeOut {
    from { opacity: 1; }
    to { opacity: 0; pointer-events: none; }
  }

  :global(body:has(.splash-active)) {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .splash-active .splash-phase-1,
    .splash-active .splash-phase-2,
    .splash-active .splash-phase-3 {
      animation: none;
      opacity: 1;
    }
    .splash-overlay.splash-fade-out {
      animation: none;
      display: none;
    }
  }
</style>
