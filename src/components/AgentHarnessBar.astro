---
const tools = ['Claude Code', 'Cursor', 'Gemini CLI'];
---

<section class="py-8 px-6 border-y border-border">
  <div class="max-w-6xl mx-auto">
    <p class="text-center text-sm text-muted-foreground uppercase tracking-wider mb-4">
      Works with your agent harness
    </p>
    <div class="flex flex-wrap items-center justify-center gap-8">
      {tools.map((tool) => (
        <span class="text-sm font-medium text-foreground/70">{tool}</span>
      ))}
    </div>
  </div>
</section>
