---
const tools = [
  { name: 'Claude Code', logo: '/images/logos/claude-code.svg' },
  { name: 'Cursor', logo: '/images/logos/cursor.svg' },
  { name: 'Gemini CLI', logo: '/images/logos/gemini-cli.svg' },
];
---

<section class="py-8 px-6 border-y border-border">
  <div class="max-w-6xl mx-auto">
    <p class="text-center text-sm text-muted-foreground uppercase tracking-wider mb-4">
      Works with your agent harness
    </p>
    <div class="flex flex-wrap items-center justify-center gap-12">
      {tools.map((tool) => (
        <img
          src={tool.logo}
          alt={tool.name}
          class="harness-logo h-8 opacity-50 hover:opacity-80 transition-opacity"
        />
      ))}
    </div>
  </div>
</section>

<style>
  :global(.dark) .harness-logo {
    filter: invert(1) brightness(0.8);
  }
</style>
