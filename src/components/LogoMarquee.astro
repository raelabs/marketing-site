---
const logos = [
  { name: 'Cisco', src: '/images/logos/cisco.svg', height: 'h-10', width: 'w-20' },
  { name: 'Twilio', src: '/images/logos/twilio.svg', height: 'h-10', width: 'w-32' },
  { name: 'Uber', src: '/images/logos/uber.svg', height: 'h-8', width: 'w-22' },
  { name: 'Indeed', src: '/images/logos/indeed.svg', height: 'h-8', width: 'w-28' },
  { name: 'Berkeley SkyDeck', src: '/images/logos/berkeley-skydeck.svg', height: 'h-6', width: 'w-56' },
  { name: 'RetailMeNot', src: '/images/logos/retailmenot.svg', height: 'h-8', width: 'w-40' },
  { name: 'ComPsych', src: '/images/logos/compsych.svg', height: 'h-8', width: 'w-40' },
  { name: 'Adept', src: '/images/logos/adept.svg', height: 'h-8', width: 'w-44' },
];
---

<section class:list={['py-12 overflow-hidden hero-reveal']} style="animation-delay: 1.1s;">
  <div class="logo-bar relative" id="logo-bar">
    <div class="fade-edge-left absolute left-0 top-0 bottom-0 w-16 z-10 pointer-events-none hidden" />
    <div class="fade-edge-right absolute right-0 top-0 bottom-0 w-16 z-10 pointer-events-none hidden" />

    <div class="logo-track flex items-center justify-center gap-10" id="logo-track">
      <div class="logo-set flex items-center gap-10 flex-shrink-0" id="logo-set-primary">
        {logos.map((logo) => (
          <div
            class:list={['logo-mask flex-shrink-0 opacity-50 hover:opacity-80 transition-opacity', logo.height || 'h-8', logo.width]}
            style={`-webkit-mask-image: url(${logo.src}); mask-image: url(${logo.src});`}
            role="img"
            aria-label={logo.name}
          ></div>
        ))}
      </div>
      <div class="logo-set flex items-center gap-10 flex-shrink-0 hidden" id="logo-set-duplicate" aria-hidden="true">
        {logos.map((logo) => (
          <div
            class:list={['logo-mask flex-shrink-0 opacity-50', logo.height || 'h-8', logo.width]}
            style={`-webkit-mask-image: url(${logo.src}); mask-image: url(${logo.src});`}
          ></div>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var SPEED = 20; // px per second — constant regardless of content width
    var bar = document.getElementById('logo-bar');
    var track = document.getElementById('logo-track');
    var primary = document.getElementById('logo-set-primary');
    var duplicate = document.getElementById('logo-set-duplicate');
    if (!bar || !track || !primary || !duplicate) return;

    function check() {
      // Reset to measure natural width
      track.style.animation = 'none';
      track.style.justifyContent = 'center';
      duplicate.classList.add('hidden');
      bar.querySelectorAll('.fade-edge-left, .fade-edge-right').forEach(function (el) {
        el.classList.add('hidden');
      });

      var containerWidth = bar.clientWidth;
      var contentWidth = primary.scrollWidth;

      if (contentWidth > containerWidth) {
        // Use flex-start to override the Tailwind justify-center class
        track.style.justifyContent = 'flex-start';
        duplicate.classList.remove('hidden');
        bar.querySelectorAll('.fade-edge-left, .fade-edge-right').forEach(function (el) {
          el.classList.remove('hidden');
        });

        // The scroll distance is one full set width + the gap between sets.
        // 2.5rem gap = 40px at default font size.
        var gap = 40;
        track.style.gap = gap + 'px';

        // Force reflow so the browser lays out the duplicate set
        void track.offsetWidth;

        var scrollDist = primary.scrollWidth + gap;
        var duration = scrollDist / SPEED;

        track.style.setProperty('--scroll-dist', '-' + scrollDist + 'px');
        track.style.animation = 'marquee ' + duration + 's linear infinite';
      }
    }

    check();
    var timer;
    window.addEventListener('resize', function () {
      clearTimeout(timer);
      timer = setTimeout(check, 150);
    });
  })();
</script>

<style>
  .logo-mask {
    background-color: currentColor;
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
  }

  .logo-bar {
    overflow: hidden;
  }

  .logo-bar:hover .logo-track {
    animation-play-state: paused;
  }

  .logo-track {
    will-change: transform;
  }

  @keyframes marquee {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(var(--scroll-dist), 0, 0); }
  }

  .fade-edge-left {
    background: linear-gradient(to right, var(--background), transparent);
  }

  .fade-edge-right {
    background: linear-gradient(to left, var(--background), transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-track {
      animation: none !important;
    }
  }
</style>
